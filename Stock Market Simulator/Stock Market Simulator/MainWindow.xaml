<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Stock_Market_Simulator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar area with three columns: nav, spacer, right content -->
        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Navigation view sits in column 0 -->
            <NavigationView x:Name="NavView"
                            Grid.Column="0"
                            PaneDisplayMode="Top"
                            IsSettingsVisible="False"
                            IsBackButtonVisible="Collapsed"
                            ItemInvoked="NavView_ItemInvoked">
                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Dashboard" Icon="Home" Tag="Dashboard" Visibility="Collapsed" x:Name="DashboardNavItem"/>
                    <NavigationViewItem Content="Portfolio" Icon="Library" Tag="Portfolio" Visibility="Collapsed" x:Name="PortfolioNavItem"/>
                    <NavigationViewItem Content="Search" Icon="Find" Tag="Search" Visibility="Collapsed" x:Name="SearchNavItem"/>
                    <NavigationViewItemSeparator Visibility="Collapsed" x:Name="SeparatorNavItem"/>
                    <NavigationViewItem Content="Login" Icon="Contact" Tag="Login" x:Name="LoginNavItem"/>
                    <NavigationViewItem Content="Logout" Icon="LeaveChat" Tag="Logout" x:Name="LogoutNavItem" Visibility="Collapsed"/>
                </NavigationView.MenuItems>
            </NavigationView>

            <!-- Right side (column 2) contains balance and other right-aligned content -->
            <StackPanel x:Name="TitleBarRightContent" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,12,0" Spacing="8">
                <StackPanel x:Name="BalancePanel" Visibility="Collapsed"
                            Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Cash:" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BalanceTextBlock" Text="$0.00" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Frame x:Name="ContentFrame" Grid.Row="1" />

        <InfoBar x:Name="NotificationInfoBar"
             Grid.Row="1"
             IsOpen="False"
             IsClosable="True"
             HorizontalAlignment="Center"
             VerticalAlignment="Bottom"
             Margin="0,0,0,24"/>
    </Grid>
</Window>