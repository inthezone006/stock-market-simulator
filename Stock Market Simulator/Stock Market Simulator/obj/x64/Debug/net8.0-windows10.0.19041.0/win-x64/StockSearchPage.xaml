<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stock_Market_Simulator.StockSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- loading / error -->
            <RowDefinition Height="*"/>
            <!-- results / chart -->
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <HyperlinkButton x:ConnectionId='9' x:Name="BackButton" Content="Back"                          />
            <TextBlock x:ConnectionId='10' x:Name="HeaderTextBlock" Text="Stock Details" FontSize="20" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressRing x:ConnectionId='7' x:Name="LoadingRing" IsActive="False" Margin="0,8,0,0"/>
            <TextBlock x:ConnectionId='8' x:Name="ErrorTextBlock" Foreground="Red" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid x:ConnectionId='2' x:Name="ResultsGrid" Margin="0,12,0,0" Visibility="Collapsed" Grid.Row="2">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock x:ConnectionId='5' x:Name="SymbolTextBlock" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:ConnectionId='6' x:Name="CompanyNameTextBlock" Foreground="Gray"/>
                    </StackPanel>
                    <TextBlock x:ConnectionId='4' x:Name="CurrentPriceTextBlock" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,0,0"/>
                </StackPanel>

                <Border Height="320" Background="Transparent" Padding="8" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <lvc:CartesianChart x:ConnectionId='3' x:Name="PriceChart" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

