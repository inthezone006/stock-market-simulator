<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stock_Market_Simulator.StockSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- loading / error -->
            <RowDefinition Height="*"/>
            <!-- results / chart -->
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8" Grid.Row="0" VerticalAlignment="Top">
            <HyperlinkButton x:Name="BackButton" Content="← Back to Dashboard" Click="BackButton_Click" />
            <TextBlock x:Name="HeaderTextBlock" Text="Stock Details" FontSize="20" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Margin="0,8,0,0"/>
            <TextBlock x:Name="ErrorTextBlock" Foreground="Red" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid x:Name="ResultsGrid" Margin="0,12,0,0" Visibility="Collapsed" Grid.Row="2">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel>
                        <TextBlock x:Name="SymbolTextBlock" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CompanyNameTextBlock" Foreground="Gray"/>
                    </StackPanel>
                    <TextBlock x:Name="CurrentPriceTextBlock" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="24,0,0,0"/>
                </StackPanel>

                <!-- purchase controls -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Shares:" VerticalAlignment="Center"/>
                    <NumberBox x:Name="SharesNumberBox" Minimum="1" Value="1" Width="100"/>
                    <Button x:Name="PurchaseButton" Content="Buy at Current Price" Click="PurchaseButton_Click"/>
                    <TextBlock x:Name="PurchaseStatusTextBlock" Foreground="Green" Visibility="Collapsed" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Border Height="320" Background="Transparent" Padding="8" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                    <lvc:CartesianChart x:Name="PriceChart" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>