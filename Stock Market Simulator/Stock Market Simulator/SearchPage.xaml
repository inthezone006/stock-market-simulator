<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stock_Market_Simulator.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="520" Spacing="12">
            <TextBlock Text="Search Stocks" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Enter symbol (e.g. AAPL)"
                            QueryIcon="Find"
                            QuerySubmitted="SearchBox_QuerySubmitted"/>
            <Button x:Name="SearchButton" Content="Search" Click="SearchButton_Click" HorizontalAlignment="Left" Width="100"/>
            <TextBlock Text="Enter a ticker symbol and press Enter or click Search." Foreground="Gray" FontSize="12"/>
        </StackPanel>
    </Grid>
</Page>